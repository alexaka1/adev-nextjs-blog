{
  "name": "adev-nextjs-blog",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "check-site-meta": "bunx --bun check-site-meta --no-analytics http://localhost:3000",
    "dev": "next dev",
    "dev:webpack": "next dev --webpack",
    "dev:sw": "next dev --experimental-https",
    "build": "next build",
    "start": "next start",
    "lint": "oxlint --type-aware --type-check",
    "lint:fix": "oxlint --type-aware --type-check --fix",
    "fmt": "oxfmt --check",
    "fmt:fix": "oxfmt",
    "renovate:debug": "LOG_LEVEL=debug bunx --bun renovate --platform=local",
    "tw:upgrade": "bunx --bun @tailwindcss/upgrade@latest"
  },
  "overrides": {
    "brace-expansion@<1.1.12": "~1.1.12",
    "brace-expansion@>=2.0.0 <2.0.2": "~2.0.2",
    "mdast-util-to-hast@<13.2.1": "^13.2.1"
  },
  "dependencies": {
    "@mdx-js/loader": "3.1.1",
    "@mdx-js/react": "3.1.1",
    "@next/mdx": "16.2.2",
    "@radix-ui/react-avatar": "1.1.11",
    "@radix-ui/react-dropdown-menu": "2.1.16",
    "@radix-ui/react-label": "2.1.8",
    "@radix-ui/react-navigation-menu": "1.2.14",
    "@radix-ui/react-slot": "1.2.4",
    "@sentry/nextjs": "10.47.0",
    "@t3-oss/env-nextjs": "0.13.11",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "1.7.0",
    "next": "16.2.3",
    "next-themes": "0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "rehype-starry-night": "2.2.0",
    "remark-frontmatter": "5.0.0",
    "remark-gfm": "4.0.1",
    "remark-mdx-frontmatter": "5.2.0",
    "tailwind-merge": "3.5.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.2.2",
    "@types/mdx": "2.0.13",
    "@types/node": "24.12.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint-plugin-import-zod": "1.2.1",
    "oxfmt": "0.44.0",
    "oxlint": "1.59.0",
    "oxlint-tsgolint": "0.20.0",
    "prettier-plugin-tailwindcss": "0.7.2",
    "tailwindcss": "4.2.2",
    "tw-animate-css": "1.4.0",
    "typescript": "6.0.2"
  },
  "engines": {
    "bun": ">=1.3.4"
  },
  "engineStrict": true,
  "trustedDependencies": [
    "@sentry/cli",
    "unrs-resolver"
  ]
